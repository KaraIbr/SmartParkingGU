    {
      "cell_type": "code",
      "source": [
        "import shutil\n",
        "import random\n",
        "\n",
        "# Configuración\n",
        "source_dir = './imagenes'\n",
        "output_dir = './dataset'\n",
        "splits = {'train': 0.7, 'test': 0.15, 'validation': 0.15}\n",
        "categories = ['ocupado', 'no_ocupado']\n",
        "\n",
        "# Crear estructura de carpetas\n",
        "for split in ['entrenamiento', 'test', 'validacion']:\n",
        "    for cat in categories:\n",
        "        os.makedirs(os.path.join(output_dir, split, cat), exist_ok=True)\n",
        "\n",
        "# Procesar cada categoría\n",
        "for cat in categories:\n",
        "    cat_source_dir = os.path.join(source_dir, cat)\n",
        "\n",
        "    if not os.path.exists(cat_source_dir):\n",
        "        print(f\"No existe la carpeta: {cat_source_dir}\")\n",
        "        continue\n",
        "\n",
        "    files = [f for f in os.listdir(cat_source_dir)\n",
        "             if f.lower().endswith(('.jpg', '.jpeg', '.png', '.bmp'))]\n",
        "\n",
        "    random.shuffle(files)\n",
        "\n",
        "    total = len(files)\n",
        "    train_count = int(total * splits['train'])\n",
        "    test_count = int(total * splits['test'])\n",
        "\n",
        "    train_files = files[:train_count]\n",
        "    test_files = files[train_count:train_count + test_count]\n",
        "    val_files = files[train_count + test_count:]\n",
        "\n",
        "    def copy_files(file_list, split_name):\n",
        "        for file in file_list:\n",
        "            src = os.path.join(cat_source_dir, file)\n",
        "            dest = os.path.join(output_dir, split_name, cat, file)\n",
        "            shutil.copyfile(src, dest)\n",
        "\n",
        "    copy_files(train_files, 'entrenamiento')\n",
        "    copy_files(test_files, 'test')\n",
        "    copy_files(val_files, 'validacion')\n",
        "\n",
        "    print(f\"{cat}: total={total}, train={len(train_files)}, test={len(test_files)}, val={len(val_files)}\")\n",
        "\n",
        "print(\"¡Listo! Dataset organizado en:\", output_dir)"
      ],
