# ============================================
# CELDA 7: Ver resultados
# ============================================
import pandas as pd
if os.path.exists('experiments/cnrpark/results.csv'):
    results = pd.read_csv('experiments/cnrpark/results.csv')
    print("Resultados de experimentos:")
    print(results.nlargest(10, 'f1_score')[['experiment_id', 'learning_rate', 'weight_decay', 'accuracy', 'f1_score']].to_string(index=False))
else:
    print("No hay resultados aun. Ejecuta los notebooks primero.")

# ============================================
# CELDA 8: Descargar resultados
# ============================================
from google.colab import files
import zipfile

# Crear archivo zip con resultados
with zipfile.ZipFile('smartparking_results.zip', 'w') as zipf:
    if os.path.exists('experiments/cnrpark/results.csv'):
        zipf.write('experiments/cnrpark/results.csv')
    if os.path.exists('experiments/cnrpark/best_model/best_model.pt'):
        zipf.write('experiments/cnrpark/best_model/best_model.pt')
    for root, dirs, files in os.walk('reports/figures'):
        for file in files:
            zipf.write(os.path.join(root, file))

files.download('smartparking_results.zip')
print("Resultados descargados!")
